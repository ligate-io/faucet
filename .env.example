# Copy to `.env` (gitignored) and fill in. Or export the vars
# directly via systemd / docker-compose / your secret manager.

# HTTP bind address. Default 0.0.0.0:8080.
FAUCET_BIND=0.0.0.0:8080

# Public REST endpoint of the target Ligate Chain network.
# Localnet:    http://127.0.0.1:12346
# devnet-1:    https://rpc.ligate.io
FAUCET_CHAIN_RPC=https://rpc.ligate.io

# Hot signer key, 64-char hex (32 bytes Ed25519 private key).
# The address derived from this key MUST be pre-funded at chain
# genesis. Generate with:
#   cargo run -p ligate-genesis-tool -- keys generate \
#       --roles faucet --output ~/.ligate-keys/devnet-1
# Then put the contents of ~/.ligate-keys/devnet-1/faucet.key here.
#
# DO NOT COMMIT this value. Inject via secret manager (1Password CLI,
# GCP Secret Manager, AWS Secrets Manager, etc.) at runtime.
FAUCET_SIGNER_KEY=

# Drip amount in nano-LGT (1 LGT = 1_000_000_000 nano).
# Default: 1_000_000_000 (= 1 LGT).
FAUCET_DRIP_AMOUNT=1000000000

# Cooldown per recipient address in seconds. Default 86400 (24h).
FAUCET_RATE_LIMIT_SECS=86400

# ---------- Chain identity ----------
# These bind the faucet's transactions to a specific chain.

# Numeric chain id (u64), from `chain_state.json` in the running
# chain's genesis config. NOT the same as the `chain_id` STRING
# `ligate-devnet-1`; this is the integer the SDK uses for tx
# domain separation.
FAUCET_CHAIN_ID=

# 32-byte chain hash (64-char hex), from a running node's
# `/v1/rollup/info` endpoint. Binds tx signatures to the runtime
# composition. A faucet built for `ligate-devnet-1` will not produce
# valid signatures for `ligate-devnet-2` even with the same key.
FAUCET_CHAIN_HASH=

# `$LGT` token id (hex), from `bank.json`'s `token_id` field at
# genesis. Computed deterministically from token name + decimals;
# stable across chain restarts on the same chain id.
FAUCET_LGT_TOKEN_ID=

# Starting nonce. Default 0. Bump on faucet redeploy if the previous
# instance had already burned some nonces (and you don't want to
# query chain to recover). The signer auto-increments per drip from
# this value.
FAUCET_STARTING_NONCE=0

# ---------- Tracing ----------
# Log level. Examples:
#   info,ligate_faucet=info     (default)
#   debug,tower_http=debug      (verbose for triage)
RUST_LOG=info,ligate_faucet=info
